# Copy this file to .env and fill in your keys. NEVER commit .env.

# https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=

# https://dashboard.api-football.com (direct, NOT RapidAPI)
API_FOOTBALL_KEY=

# https://www.thesportsdb.com/free_sports_api
# "123" is the public test key and works for basic v1 endpoints.
THESPORTSDB_KEY=123

# Supabase project (create at https://supabase.com/dashboard) —
# values are under Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key: cron/writes only. NEVER ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=
